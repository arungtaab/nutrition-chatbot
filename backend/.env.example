# Copy to .env and load before `python app.py`, or export in your shell / PaaS dashboard.

OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2

# RAG index: chroma (default, needs chromadb) or sqlite (small disk, set on PythonAnywhere free)
# VECTOR_STORE=sqlite
# SQLITE_RAG_PATH=rag_vectors.db

# SQLite and Chroma paths (relative to backend/ unless absolute)
# DB_PATH=chat_history.db
# CHROMA_PATH=chroma_db

# Comma-separated browser origins allowed to call the API
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.example

# Production hardening (recommended on public APIs)
# RATE_LIMIT_ENABLED=true
# CHAT_RATE_LIMIT=60 per minute
# HIDE_INTERNAL_ERRORS=true

# Ingest: set DISABLE_INGEST=true to turn off POST /api/ingest entirely, or set a secret:
# DISABLE_INGEST=false
# INGEST_SECRET=your-long-random-string
# Then: curl -H "X-Ingest-Secret: $INGEST_SECRET" -X POST .../api/ingest
